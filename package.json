{
  "name": "laclau-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:prepare:scanner": "node src/scripts/ensureScannerIndexes.js",
    "db:prepare:core": "node src/scripts/ensureCoreSchema.js",
    "db:prepare:all": "npm run db:prepare:scanner && npm run db:prepare:core",
    "auth:hash-password": "node src/scripts/hashPassword.js",
    "auth:cleanup-sessions": "node src/scripts/cleanupExpiredSessions.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mysql2": "^3.14.5"
  },
  "devDependencies": {
    "vitest": "^4.1.5"
  }
}
